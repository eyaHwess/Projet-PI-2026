{{ form_start(form, {
    'action': (activity is defined and activity.id) ? path('app_activity_edit', {routineId: routine.id, id: activity.id}) : path('app_activity_new', {routineId: routine.id}),
    'method': 'POST',
    'attr': {'class': 'needs-validation', 'novalidate': ''}
}) }}
    <div class="row g-3">
        <div class="col-12">
            {{ form_label(form.title, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.title, {'attr': {'class': 'form-control form-control-lg', 'placeholder': 'Ex: Courir 30 minutes'}}) }}
            {{ form_errors(form.title) }}
        </div>

        <div class="col-md-6">
            {{ form_label(form.startTime, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.startTime, {'attr': {'class': 'form-control form-control-lg'}}) }}
            {{ form_errors(form.startTime) }}
        </div>

        <div class="col-md-6">
            {{ form_label(form.duration, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.duration, {'attr': {'class': 'form-control form-control-lg'}}) }}
            {{ form_errors(form.duration) }}
        </div>

        <div class="col-12">
            {{ form_label(form.status, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.status, {'attr': {'class': 'form-select form-select-lg'}}) }}
            {{ form_errors(form.status) }}
        </div>

        <div class="col-12">
            <div class="p-3 border rounded-3" style="background:#f8f5ff; border-color:#d8b4fe !important;">
                <div class="form-check d-flex align-items-center gap-2 mb-0">
                    {{ form_widget(form.hasReminder, {'attr': {'class': 'form-check-input', 'style': 'width:1.2em;height:1.2em;cursor:pointer;accent-color:#7c3aed'}}) }}
                    <label class="form-check-label fw-semibold" style="cursor:pointer;color:#5b21b6">
                        🔔 Activer un rappel pour cette activité
                    </label>
                </div>
            </div>
        </div>

        <div class="col-12" id="reminderField" {% if not form.hasReminder.vars.checked %}style="display: none;"{% endif %}>
            <div class="p-3 border rounded-3" style="background:#fefce8; border-color:#fde68a !important;">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span>⏰</span>
                    {{ form_label(form.reminderAt, 'Date et heure du rappel', {'label_attr': {'class': 'form-label mb-0 fw-semibold', 'style': 'color:#92400e'}}) }}
                </div>
                {{ form_widget(form.reminderAt, {'attr': {'class': 'form-control form-control-lg'}}) }}
                {{ form_errors(form.reminderAt) }}
                <small class="text-muted mt-1 d-block">Le rappel sera envoyé à cette date et heure précises.</small>
            </div>
<script>
    document.querySelector('input[name="{{ form.hasReminder.vars.full_name }}"]')?.addEventListener('change', function() {
        document.getElementById('reminderField').style.display = this.checked ? 'block' : 'none';
    });
</script>

        </div>
    </div>

    <div class="d-flex gap-3 mt-4 pt-4 border-top">
        <button type="submit" class="btn btn-orange flex-grow-1">
            <i class="bi bi-check-circle me-2"></i>Enregistrer
        </button>
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
            Annuler
        </button>
    </div>
{{ form_end(form) }}
