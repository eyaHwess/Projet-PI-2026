<!doctype html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Kayouta – Organise ta vie, atteins tes objectifs</title>
    <meta name="description" content="Kayouta t'aide à créer des routines, fixer des objectifs et te connecter avec un coach personnel. Rejoins des milliers d'utilisateurs qui transforment leur quotidien.">
    <link rel="icon" href="{{ asset('images/favicon.ico') }}" type="image/x-icon">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Syne:wght@700;800&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --purple:    #7c3aed;
            --purple-l:  #9f67f7;
            --purple-d:  #5b21b6;
            --purple-10: #f5f3ff;
            --purple-20: #ede9fe;
            --zinc-900:  #18181b;
            --zinc-600:  #52525b;
            --zinc-400:  #a1a1aa;
            --zinc-200:  #e4e4e7;
            --white:     #ffffff;
        }

        html { scroll-behavior: smooth; }

        body {
            font-family: 'Inter', sans-serif;
            background: #fff;
            color: var(--zinc-900);
            overflow-x: hidden;
        }

        /* ─── NAVBAR ─── */
        .navbar {
            position: fixed; top: 0; left: 0; right: 0; z-index: 100;
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 5%;
            height: 68px;
            background: rgba(255,255,255,0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(124,58,237,.1);
            transition: background .3s;
        }
        .navbar.scrolled { background: rgba(255,255,255,0.97); box-shadow: 0 2px 20px rgba(0,0,0,.07); }
        .nav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
        .nav-logo img { height: 32px; }
        .nav-links { display: flex; align-items: center; gap: 6px; }
        .nav-links a {
            padding: 7px 14px; border-radius: 8px;
            font-size: .9rem; font-weight: 500; color: var(--zinc-600);
            text-decoration: none; transition: color .2s, background .2s;
        }
        .nav-links a:hover { color: var(--purple); background: var(--purple-10); }
        .nav-cta {
            display: flex; gap: 10px; align-items: center;
        }
        .btn-ghost {
            padding: 9px 20px; border-radius: 10px;
            font-size: .9rem; font-weight: 600; color: var(--zinc-600);
            background: transparent; border: 1.5px solid var(--zinc-200);
            cursor: pointer; text-decoration: none; transition: all .2s;
        }
        .btn-ghost:hover { border-color: var(--purple-l); color: var(--purple); }
        .btn-primary {
            padding: 9px 22px; border-radius: 10px;
            font-size: .9rem; font-weight: 600; color: #fff;
            background: var(--purple); border: none;
            cursor: pointer; text-decoration: none; transition: all .2s;
            box-shadow: 0 2px 12px rgba(124,58,237,.35);
        }
        .btn-primary:hover { background: var(--purple-d); box-shadow: 0 4px 20px rgba(124,58,237,.45); transform: translateY(-1px); }
        .nav-hamburger { display: none; background: none; border: none; cursor: pointer; padding: 6px; }

        /* ─── HERO ─── */
        .hero {
            min-height: 100vh;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            text-align: center;
            padding: 120px 5% 80px;
            position: relative;
            overflow: hidden;
        }
        .hero-bg {
            position: absolute; inset: 0; z-index: 0;
            background: radial-gradient(ellipse 80% 60% at 50% -10%, #ede9fe 0%, #fff 70%);
        }
        .hero-orb {
            position: absolute; border-radius: 50%; filter: blur(80px); opacity: .35; pointer-events: none;
        }
        .hero-orb-1 { width: 500px; height: 500px; background: #7c3aed; top: -150px; left: -100px; }
        .hero-orb-2 { width: 400px; height: 400px; background: #a855f7; top: 0; right: -100px; }
        .hero-orb-3 { width: 300px; height: 300px; background: #e879f9; bottom: 0; left: 30%; }

        .hero-badge {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 6px 16px 6px 8px;
            background: rgba(255,255,255,.8); backdrop-filter: blur(10px);
            border: 1.5px solid rgba(124,58,237,.2);
            border-radius: 100px; font-size: .82rem; font-weight: 600;
            color: var(--purple); margin-bottom: 28px; position: relative; z-index: 1;
            animation: fadeInUp .6s ease both;
        }
        .hero-badge-dot {
            width: 20px; height: 20px; border-radius: 50%;
            background: var(--purple); color: #fff;
            display: flex; align-items: center; justify-content: center; font-size: .7rem;
        }
        .hero-title {
            font-family: 'Syne', sans-serif;
            font-size: clamp(2.4rem, 6vw, 4.8rem);
            font-weight: 800; line-height: 1.08; letter-spacing: -.03em;
            max-width: 820px; position: relative; z-index: 1;
            animation: fadeInUp .7s .1s ease both;
        }
        .hero-title .gradient-text {
            background: linear-gradient(135deg, #7c3aed, #c026d3, #ec4899);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .hero-sub {
            font-size: 1.15rem; color: var(--zinc-600); max-width: 560px;
            line-height: 1.7; margin-top: 20px; position: relative; z-index: 1;
            animation: fadeInUp .7s .2s ease both;
        }
        .hero-actions {
            display: flex; gap: 14px; margin-top: 36px; position: relative; z-index: 1;
            animation: fadeInUp .7s .3s ease both; flex-wrap: wrap; justify-content: center;
        }
        .btn-hero-primary {
            padding: 14px 32px; border-radius: 12px;
            font-size: 1rem; font-weight: 700; color: #fff;
            background: linear-gradient(135deg, var(--purple), #9333ea);
            border: none; cursor: pointer; text-decoration: none;
            box-shadow: 0 8px 30px rgba(124,58,237,.4);
            transition: all .25s; display: inline-flex; align-items: center; gap: 8px;
        }
        .btn-hero-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(124,58,237,.5); }
        .btn-hero-secondary {
            padding: 14px 28px; border-radius: 12px;
            font-size: 1rem; font-weight: 600; color: var(--zinc-600);
            background: rgba(255,255,255,.9); border: 1.5px solid var(--zinc-200);
            cursor: pointer; text-decoration: none; transition: all .25s;
            display: inline-flex; align-items: center; gap: 8px;
        }
        .btn-hero-secondary:hover { border-color: var(--purple-l); color: var(--purple); background: var(--purple-10); }
        .hero-social-proof {
            display: flex; align-items: center; gap: 12px; margin-top: 40px;
            position: relative; z-index: 1; animation: fadeInUp .7s .4s ease both;
        }
        .hero-avatars { display: flex; }
        .hero-avatars span {
            width: 34px; height: 34px; border-radius: 50%;
            border: 2px solid #fff; margin-left: -10px;
            display: flex; align-items: center; justify-content: center;
            font-size: .7rem; font-weight: 700; color: #fff;
        }
        .hero-avatars span:first-child { margin-left: 0; }
        .hero-social-text { font-size: .87rem; color: var(--zinc-600); }
        .hero-social-text strong { color: var(--zinc-900); }
        .hero-stars { color: #f59e0b; letter-spacing: -2px; font-size: .9rem; }

        /* ─── FLOATING CARD (hero preview) ─── */
        .hero-preview {
            margin-top: 60px; position: relative; z-index: 1;
            width: 100%; max-width: 860px;
            animation: fadeInUp .8s .5s ease both;
        }
        .hero-preview-card {
            background: rgba(255,255,255,.9); backdrop-filter: blur(20px);
            border: 1px solid rgba(124,58,237,.15);
            border-radius: 20px; padding: 24px;
            box-shadow: 0 25px 80px rgba(124,58,237,.12), 0 2px 0 rgba(255,255,255,.8) inset;
        }
        .preview-header {
            display: flex; align-items: center; gap: 8px; margin-bottom: 20px;
        }
        .preview-dot { width: 12px; height: 12px; border-radius: 50%; }
        .preview-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
        .preview-stat {
            background: var(--purple-10); border-radius: 12px; padding: 16px;
            display: flex; flex-direction: column; gap: 6px;
        }
        .preview-stat-num { font-size: 1.6rem; font-weight: 800; color: var(--purple); font-family: 'Syne', sans-serif; }
        .preview-stat-label { font-size: .78rem; color: var(--zinc-600); font-weight: 500; }
        .preview-progress {
            margin-top: 16px; background: var(--purple-20); border-radius: 12px; padding: 16px;
        }
        .preview-progress-label { display: flex; justify-content: space-between; font-size: .82rem; font-weight: 600; margin-bottom: 10px; }
        .progress-bar-wrap { background: var(--zinc-200); border-radius: 100px; height: 8px; overflow: hidden; }
        .progress-bar-fill { height: 100%; border-radius: 100px; background: linear-gradient(90deg, var(--purple), #c026d3); }

        /* ─── STATS STRIP ─── */
        .stats-strip {
            display: grid; grid-template-columns: repeat(3, 1fr);
            border-top: 1px solid var(--zinc-200); border-bottom: 1px solid var(--zinc-200);
            padding: 40px 5%;
        }
        .stat-item {
            text-align: center; padding: 20px;
            border-right: 1px solid var(--zinc-200);
        }
        .stat-item:last-child { border-right: none; }
        .stat-num { font-family: 'Syne', sans-serif; font-size: 2.8rem; font-weight: 800; color: var(--purple); }
        .stat-label { font-size: .9rem; color: var(--zinc-600); margin-top: 6px; line-height: 1.4; }

        /* ─── SECTION HEADER ─── */
        .section-tag {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 5px 14px; border-radius: 100px;
            background: var(--purple-20); color: var(--purple);
            font-size: .8rem; font-weight: 700; letter-spacing: .05em; text-transform: uppercase;
            margin-bottom: 16px;
        }
        .section-title {
            font-family: 'Syne', sans-serif; font-size: clamp(1.8rem, 4vw, 2.8rem);
            font-weight: 800; letter-spacing: -.02em; line-height: 1.15;
        }
        .section-sub { font-size: 1rem; color: var(--zinc-600); line-height: 1.7; max-width: 480px; margin-top: 12px; }

        /* ─── FEATURES ─── */
        .features-section { padding: 100px 5%; }
        .features-inner { max-width: 1200px; margin: 0 auto; }
        .features-header { text-align: center; margin-bottom: 64px; }
        .features-header .section-sub { margin: 12px auto 0; }
        .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
        .feature-card {
            background: #fff; border: 1.5px solid var(--zinc-200);
            border-radius: 20px; padding: 28px;
            transition: all .3s; position: relative; overflow: hidden;
        }
        .feature-card::before {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(135deg, var(--purple-10), transparent);
            opacity: 0; transition: opacity .3s;
        }
        .feature-card:hover { border-color: rgba(124,58,237,.3); transform: translateY(-4px); box-shadow: 0 16px 48px rgba(124,58,237,.12); }
        .feature-card:hover::before { opacity: 1; }
        .feature-card.featured {
            background: linear-gradient(135deg, #7c3aed, #9333ea);
            border-color: transparent; color: #fff;
        }
        .feature-card.featured .feature-label { color: rgba(255,255,255,.7); }
        .feature-card.featured .feature-desc { color: rgba(255,255,255,.8); }
        .feature-icon {
            width: 48px; height: 48px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem; margin-bottom: 18px; position: relative; z-index: 1;
        }
        .feature-label { font-size: .8rem; font-weight: 700; color: var(--purple); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 8px; position: relative; z-index: 1; }
        .feature-title { font-family: 'Syne', sans-serif; font-size: 1.15rem; font-weight: 700; margin-bottom: 10px; position: relative; z-index: 1; }
        .feature-desc { font-size: .9rem; color: var(--zinc-600); line-height: 1.6; position: relative; z-index: 1; }
        .feature-card.featured .feature-label { color: rgba(255,255,255,.7); }

        /* ─── HOW IT WORKS ─── */
        .how-section { padding: 100px 5%; background: var(--purple-10); }
        .how-inner { max-width: 1100px; margin: 0 auto; }
        .how-header { text-align: center; margin-bottom: 64px; }
        .how-header .section-sub { margin: 12px auto 0; }
        .how-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; position: relative; }
        .how-steps::before {
            content: ''; position: absolute; top: 40px; left: 10%; right: 10%; height: 2px;
            background: linear-gradient(90deg, var(--purple), #c026d3);
            z-index: 0;
        }
        .how-step { text-align: center; padding: 0 20px; position: relative; z-index: 1; }
        .step-num {
            width: 80px; height: 80px; border-radius: 50%;
            background: #fff; border: 3px solid var(--purple);
            display: flex; align-items: center; justify-content: center;
            font-family: 'Syne', sans-serif; font-size: 1.6rem; font-weight: 800; color: var(--purple);
            margin: 0 auto 20px; box-shadow: 0 4px 20px rgba(124,58,237,.2);
        }
        .step-title { font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700; margin-bottom: 8px; }
        .step-desc { font-size: .87rem; color: var(--zinc-600); line-height: 1.6; }

        /* ─── TEAM ─── */
        .team-section { padding: 100px 5%; }
        .team-inner { max-width: 1200px; margin: 0 auto; }
        .team-header { text-align: center; margin-bottom: 64px; }
        .team-header .section-sub { margin: 12px auto 0; }
        .team-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 28px; }
        .team-card {
            width: 210px; text-align: center;
            background: #fff; border: 1.5px solid var(--zinc-200);
            border-radius: 20px; padding: 28px 20px 22px;
            transition: all .3s;
        }
        .team-card:hover { border-color: rgba(124,58,237,.3); transform: translateY(-6px); box-shadow: 0 16px 40px rgba(124,58,237,.12); }
        .team-avatar-circle {
            width: 80px; height: 80px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-family: 'Syne', sans-serif; font-size: 1.6rem; font-weight: 800; color: #fff;
            margin: 0 auto 16px;
            box-shadow: 0 4px 16px rgba(0,0,0,.12);
        }
        .team-name { font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700; margin-bottom: 4px; }
        .team-role { font-size: .8rem; color: var(--zinc-400); font-weight: 500; }
        .team-badge {
            display: inline-block; margin-top: 10px;
            padding: 3px 10px; border-radius: 100px;
            font-size: .72rem; font-weight: 600; color: var(--purple); background: var(--purple-20);
        }

        /* ─── TESTIMONIALS ─── */
        .testimonials-section { padding: 100px 5%; background: linear-gradient(180deg, #fff 0%, var(--purple-10) 100%); }
        .testimonials-inner { max-width: 1100px; margin: 0 auto; }
        .testimonials-header { text-align: center; margin-bottom: 64px; }
        .testimonials-header .section-sub { margin: 12px auto 0; }
        .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; align-items: start; }
        .testimonial-card {
            background: #fff; border: 1.5px solid var(--zinc-200);
            border-radius: 20px; padding: 28px;
            transition: all .3s;
        }
        .testimonial-card:hover { border-color: rgba(124,58,237,.2); box-shadow: 0 12px 40px rgba(124,58,237,.1); }
        .testimonial-card.featured {
            background: linear-gradient(135deg, #7c3aed, #9333ea);
            border: none; transform: scale(1.03);
            box-shadow: 0 20px 60px rgba(124,58,237,.35);
        }
        .stars { color: #f59e0b; font-size: 1rem; letter-spacing: -1px; margin-bottom: 16px; }
        .testimonial-card.featured .stars { color: #fde68a; }
        .testimonial-text { font-size: .93rem; line-height: 1.7; color: var(--zinc-600); }
        .testimonial-card.featured .testimonial-text { color: rgba(255,255,255,.9); }
        .testimonial-author { display: flex; align-items: center; gap: 12px; margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--zinc-200); }
        .testimonial-card.featured .testimonial-author { border-top-color: rgba(255,255,255,.2); }
        .author-avatar {
            width: 40px; height: 40px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: .8rem; font-weight: 700; color: var(--purple); background: var(--purple-20);
            flex-shrink: 0;
        }
        .testimonial-card.featured .author-avatar { color: #7c3aed; background: #fff; }
        .author-name { font-weight: 700; font-size: .9rem; }
        .testimonial-card.featured .author-name { color: #fff; }
        .author-role { font-size: .78rem; color: var(--zinc-400); }
        .testimonial-card.featured .author-role { color: rgba(255,255,255,.6); }

        /* ─── FAQ ─── */
        .faq-section { padding: 100px 5%; }
        .faq-inner { max-width: 760px; margin: 0 auto; }
        .faq-header { text-align: center; margin-bottom: 48px; }
        .faq-header .section-sub { margin: 12px auto 0; }
        .faq-item {
            border: 1.5px solid var(--zinc-200); border-radius: 14px;
            margin-bottom: 12px; overflow: hidden; transition: border-color .2s;
        }
        .faq-item:hover { border-color: rgba(124,58,237,.3); }
        .faq-item[open] { border-color: rgba(124,58,237,.4); }
        .faq-summary {
            display: flex; justify-content: space-between; align-items: center;
            padding: 18px 22px; cursor: pointer; list-style: none;
            font-weight: 600; font-size: .95rem;
            user-select: none;
        }
        .faq-summary::-webkit-details-marker { display: none; }
        .faq-icon {
            width: 28px; height: 28px; border-radius: 50%;
            background: var(--purple-20); color: var(--purple);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; flex-shrink: 0; transition: transform .3s, background .2s;
        }
        .faq-item[open] .faq-icon { transform: rotate(45deg); background: var(--purple); color: #fff; }
        .faq-body { padding: 0 22px 18px; font-size: .9rem; color: var(--zinc-600); line-height: 1.7; }

        /* ─── CTA BANNER ─── */
        .cta-section { padding: 40px 5% 80px; }
        .cta-card {
            max-width: 1100px; margin: 0 auto;
            background: linear-gradient(135deg, #7c3aed 0%, #9333ea 50%, #c026d3 100%);
            border-radius: 28px; padding: 64px 60px;
            display: flex; align-items: center; justify-content: space-between;
            gap: 40px; position: relative; overflow: hidden;
            box-shadow: 0 30px 80px rgba(124,58,237,.3);
        }
        .cta-card::before {
            content: ''; position: absolute; inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        }
        .cta-text { position: relative; z-index: 1; }
        .cta-title { font-family: 'Syne', sans-serif; font-size: 2rem; font-weight: 800; color: #fff; margin-bottom: 12px; line-height: 1.2; }
        .cta-sub { font-size: 1rem; color: rgba(255,255,255,.8); line-height: 1.6; max-width: 400px; }
        .cta-actions { display: flex; gap: 14px; flex-shrink: 0; position: relative; z-index: 1; flex-wrap: wrap; justify-content: flex-end; }
        .btn-cta-white {
            padding: 14px 28px; border-radius: 12px; font-size: .95rem; font-weight: 700;
            color: var(--purple); background: #fff; border: none; cursor: pointer;
            text-decoration: none; transition: all .2s; white-space: nowrap;
        }
        .btn-cta-white:hover { background: var(--purple-10); transform: translateY(-2px); }
        .btn-cta-outline {
            padding: 14px 28px; border-radius: 12px; font-size: .95rem; font-weight: 600;
            color: #fff; background: rgba(255,255,255,.15); border: 1.5px solid rgba(255,255,255,.4);
            cursor: pointer; text-decoration: none; transition: all .2s; white-space: nowrap;
        }
        .btn-cta-outline:hover { background: rgba(255,255,255,.25); }

        /* ─── FOOTER ─── */
        .footer { padding: 60px 5% 40px; border-top: 1px solid var(--zinc-200); }
        .footer-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; }
        .footer-brand-logo { height: 30px; margin-bottom: 14px; }
        .footer-brand-desc { font-size: .88rem; color: var(--zinc-600); line-height: 1.7; max-width: 260px; }
        .footer-col-title { font-weight: 700; font-size: .88rem; text-transform: uppercase; letter-spacing: .07em; color: var(--zinc-900); margin-bottom: 16px; }
        .footer-links { display: flex; flex-direction: column; gap: 10px; }
        .footer-links a { font-size: .9rem; color: var(--zinc-600); text-decoration: none; transition: color .2s; }
        .footer-links a:hover { color: var(--purple); }
        .footer-links span { font-size: .9rem; color: var(--zinc-600); }
        .footer-bottom { max-width: 1100px; margin: 48px auto 0; padding-top: 24px; border-top: 1px solid var(--zinc-200); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
        .footer-copy { font-size: .83rem; color: var(--zinc-400); }
