{% extends 'base.html.twig' %}

{% block title %}Dashboard Coach{% endblock %}

{% block stylesheets %}
    <style>
        /* Coach dashboard – aligned with DayFlow (Tailwind + orange) */
        .coach-hero {
            background: linear-gradient(135deg, #ea580c 0%, #c2410c 40%, #9a3412 100%);
            position: relative;
            overflow: hidden;
        }
        .coach-hero::before {
            content: '';
            position: absolute;
            top: -100px; right: -100px;
            width: 320px; height: 320px;
            background: radial-gradient(circle, rgba(255,255,255,.12) 0%, transparent 70%);
            border-radius: 50%;
        }
        .coach-hero::after {
            content: '';
            position: absolute;
            bottom: -80px; left: -60px;
            width: 280px; height: 280px;
            background: radial-gradient(circle, rgba(254,215,170,.2) 0%, transparent 65%);
            border-radius: 50%;
        }
        .stat-card {
            transition: transform .2s ease, box-shadow .2s ease;
        }
        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 40px rgba(0,0,0,.08);
        }
        .req-card-coach {
            transition: box-shadow .2s ease, transform .2s ease;
        }
        .req-card-coach:hover {
            box-shadow: 0 8px 32px rgba(0,0,0,.06);
            transform: translateY(-2px);
        }
        .req-card-coach.border-l-pending { border-left: 4px solid #f59e0b; }
        .req-card-coach.border-l-accepted { border-left: 4px solid #10b981; }
        .req-card-coach.border-l-declined { border-left: 4px solid #ef4444; }
        .req-message-box::before {
            content: '\201C';
            font-size: 2rem;
            line-height: 1;
            color: #ea580c;
            opacity: .35;
            position: absolute;
            top: .25rem;
            left: .5rem;
        }
    </style>
{% endblock %}

{% block body %}

    {# Hero #}
    <div class="coach-hero pt-8 pb-10 relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <a href="{{ path('user_dashboard') }}" class="inline-flex items-center gap-2 text-sm font-medium text-white/80 hover:text-white transition mb-4">
                <i class="bi bi-arrow-left"></i>
                Tableau de bord
            </a>
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 border border-white/20 text-white/90 text-xs font-semibold uppercase tracking-wide backdrop-blur-sm mb-4">
                <i class="bi bi-person-workspace"></i>
                Coach Dashboard
            </div>
            <h1 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight">Demandes de coaching</h1>
            <p class="mt-2 text-white/70 max-w-xl">Gérez les demandes reçues et planifiez vos sessions.</p>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">

        {# Stats #}
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 -mt-8 relative z-10">
            <div class="stat-card bg-white rounded-2xl p-5 shadow-lg border border-gray-100 flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl bg-amber-100 flex items-center justify-center flex-shrink-0">
                    <i class="bi bi-clock-history text-amber-600 text-xl"></i>
                </div>
                <div>
                    <div class="text-2xl font-extrabold text-gray-900">{{ stats.pending }}</div>
                    <div class="text-sm font-medium text-gray-500">En attente</div>
                </div>
            </div>
            <div class="stat-card bg-white rounded-2xl p-5 shadow-lg border border-gray-100 flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl bg-emerald-100 flex items-center justify-center flex-shrink-0">
                    <i class="bi bi-check-circle-fill text-emerald-600 text-xl"></i>
                </div>
                <div>
                    <div class="text-2xl font-extrabold text-gray-900">{{ stats.accepted }}</div>
                    <div class="text-sm font-medium text-gray-500">Acceptées</div>
                </div>
            </div>
            <div class="stat-card bg-white rounded-2xl p-5 shadow-lg border border-gray-100 flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl bg-orange-100 flex items-center justify-center flex-shrink-0">
                    <i class="bi bi-calendar-day text-orange-600 text-xl"></i>
                </div>
                <div>
                    <div class="text-2xl font-extrabold text-gray-900">{{ stats.sessions_today }}</div>
                    <div class="text-sm font-medium text-gray-500">Sessions aujourd'hui</div>
                </div>
            </div>
        </div>

        {# Filters #}
        <div class="mt-8 bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
            <div class="flex items-center gap-2 mb-4">
                <i class="bi bi-funnel-fill text-orange-500"></i>
                <span class="font-bold text-gray-900">Filtres</span>
            </div>
            <form method="get" action="{{ path('app_coaching_request_index') }}" class="space-y-4" id="filter-form">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-4 items-end">
                    <div class="lg:col-span-2">
                        <label class="block text-sm font-semibold text-gray-500 mb-1">Recherche</label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"><i class="bi bi-search"></i></span>
                            <input type="text" name="search" class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-200 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 outline-none transition text-sm" placeholder="Nom, email, message…" value="{{ filters.search|default('') }}">
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-500 mb-1">Statut</label>
                        <select name="status" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 outline-none transition text-sm bg-white">
                            <option value="">Tous</option>
                            <option value="pending"   {{ filters.status|default('') == 'pending'   ? 'selected' : '' }}>En attente</option>
                            <option value="accepted"  {{ filters.status|default('') == 'accepted'  ? 'selected' : '' }}>Acceptée</option>
                            <option value="declined"  {{ filters.status|default('') == 'declined'  ? 'selected' : '' }}>Refusée</option>
                            <option value="planned"   {{ filters.status|default('') == 'planned'   ? 'selected' : '' }}>Planifiée</option>
                            <option value="completed" {{ filters.status|default('') == 'completed' ? 'selected' : '' }}>Terminée</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-500 mb-1">Priorité</label>
                        <select name="priority" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 outline-none transition text-sm bg-white">
                            <option value="">Toutes</option>
                            <option value="urgent" {{ filters.priority|default('') == 'urgent' ? 'selected' : '' }}>Urgent</option>
                            <option value="normal" {{ filters.priority|default('') == 'normal' ? 'selected' : '' }}>Normal</option>
                            <option value="medium" {{ filters.priority|default('') == 'medium' ? 'selected' : '' }}>Faible</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-500 mb-1">Du</label>
                        <input type="date" name="date_from" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 outline-none transition text-sm" value="{{ filters.date_from|default('') }}">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-500 mb-1">Au</label>
                        <input type="date" name="date_to" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 outline-none transition text-sm" value="{{ filters.date_to|default('') }}">
                    </div>
                </div>
                <div class="flex flex-wrap items-center gap-3">
                    <button type="submit" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-orange-500 hover:bg-orange-600 text-white font-semibold text-sm shadow-md hover:shadow-lg transition">
                        <i class="bi bi-funnel"></i>
                        Appliquer
                    </button>
                    <a href="{{ path('app_coaching_request_index') }}" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full border border-gray-300 text-gray-600 hover:bg-gray-50 text-sm font-medium transition">
                        <i class="bi bi-x-circle"></i>
                        Réinitialiser
                    </a>
                    {% if filters.search or filters.status or filters.date_from or filters.date_to or filters.priority %}
                        <span class="text-gray-500 text-sm">{{ allRequests|length }} résultat(s)</span>
                    {% endif %}
                </div>
            </form>
        </div>

        {# Pending requests #}
        {% if pendingRequests|length > 0 %}
            <div class="flex items-center gap-2 mt-10 mb-3">
                <span class="w-2 h-2 rounded-full bg-amber-500"></span>
                <span class="font-bold text-gray-900">En attente</span>
                <span class="ml-1 px-2.5 py-0.5 rounded-full bg-orange-500 text-white text-xs font-bold">{{ pendingRequests|length }}</span>
            </div>

            {% for req in pendingRequests %}
                {% set waitSec = "now"|date("U") - req.createdAt|date("U") %}
                <div class="req-card-coach border-l-pending bg-white rounded-2xl border border-gray-200 shadow-sm p-5 mb-4">
                    <div class="flex flex-col sm:flex-row gap-4 sm:gap-5">
                        <div class="w-12 h-12 rounded-full bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-white font-bold text-lg flex-shrink-0">
                            {{ req.user.firstName ? req.user.firstName|first|upper : req.user.email|first|upper }}
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex flex-wrap items-center gap-2 mb-2">
                                <span class="font-bold text-gray-900">{{ req.user.firstName }} {{ req.user.lastName }}</span>
                                <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-amber-100 text-amber-800 text-xs font-semibold"><i class="bi bi-clock-history"></i> En attente</span>
                                {% if req.priority == 'urgent' %}
                                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-red-100 text-red-700 text-xs font-semibold"><i class="bi bi-exclamation-triangle-fill"></i> Urgent</span>
                                {% elseif req.priority == 'medium' %}
                                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-gray-100 text-gray-600 text-xs font-semibold">Faible</span>
                                {% else %}
                                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-blue-100 text-blue-700 text-xs font-semibold">Normal</span>
                                {% endif %}
                                {% if waitSec >= 172800 %}
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-red-50 text-red-600 border border-red-200 text-xs font-semibold"><i class="bi bi-alarm-fill"></i> &gt; 48h</span>
                                {% endif %}
                            </div>
                            <div class="flex flex-wrap gap-4 text-sm text-gray-500 mb-3">
                                <span><i class="bi bi-envelope me-1"></i>{{ req.user.email }}</span>
                                <span><i class="bi bi-calendar3 me-1"></i>{{ req.createdAt|date('d/m/Y à H:i') }}</span>
                                <span class="inline-flex items-center gap-1 text-amber-700">
                                    <i class="bi bi-hourglass-split"></i>
                                    {% if waitSec >= 86400 %}{{ (waitSec / 86400)|round(0, 'floor') }}j
                                    {% elseif waitSec >= 3600 %}{{ (waitSec / 3600)|round(0, 'floor') }}h
                                    {% else %}{{ (waitSec / 60)|round(0, 'floor') }}min{% endif %}
                                </span>
                            </div>
                            <div class="req-message-box relative bg-gray-50 border border-gray-200 rounded-xl py-3 px-4 pl-8 text-sm text-gray-600">{{ req.message }}</div>
                        </div>
                        <div class="flex sm:flex-col gap-2 flex-shrink-0">
                            <form action="{{ path('app_coaching_request_accept', {id: req.id}) }}" method="post" class="accept-form inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('accept-request' ~ req.id) }}">
                                <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center gap-1.5 px-4 py-2.5 rounded-xl bg-emerald-100 text-emerald-700 hover:bg-emerald-200 font-semibold text-sm transition">
                                    <i class="bi bi-check-lg"></i> Accepter
                                </button>
                            </form>
                            <form action="{{ path('app_coaching_request_decline', {id: req.id}) }}" method="post" class="decline-form inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('decline-request' ~ req.id) }}">
                                <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center gap-1.5 px-4 py-2.5 rounded-xl bg-red-100 text-red-700 hover:bg-red-200 font-semibold text-sm transition">
                                    <i class="bi bi-x-lg"></i> Refuser
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
            <div class="mb-2"></div>
        {% endif %}

        {# All requests #}
        <div class="flex items-center gap-2 mt-8 mb-3">
            <span class="w-2 h-2 rounded-full bg-orange-500"></span>
            <span class="font-bold text-gray-900">Toutes les demandes</span>
            <span class="ml-1 px-2.5 py-0.5 rounded-full bg-orange-500 text-white text-xs font-bold">{{ allRequests|length }}</span>
        </div>

        {% if allRequests|length > 0 %}
            {% for req in allRequests %}
                {% set waitSec = "now"|date("U") - req.createdAt|date("U") %}
                {% set borderClass = req.status == 'pending' ? 'border-l-pending' : (req.status == 'accepted' ? 'border-l-accepted' : 'border-l-declined') %}
                <div class="req-card-coach {{ borderClass }} bg-white rounded-2xl border border-gray-200 shadow-sm p-5 mb-4">
                    <div class="flex flex-col sm:flex-row gap-4 sm:gap-5">
                        <div class="w-12 h-12 rounded-full bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-white font-bold text-lg flex-shrink-0">
                            {{ req.user.firstName ? req.user.firstName|first|upper : req.user.email|first|upper }}
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex flex-wrap items-center gap-2 mb-2">
                                <span class="font-bold text-gray-900">{{ req.user.firstName }} {{ req.user.lastName }}</span>
                                {% if req.status == 'pending' %}
                                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-amber-100 text-amber-800 text-xs font-semibold"><i class="bi bi-clock-history"></i> En attente</span>
                                {% elseif req.status == 'declined' %}
                                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-red-100 text-red-700 text-xs font-semibold"><i class="bi bi-x-circle"></i> Refusée</span>
                                {% elseif req.session and req.session.status == 'completed' %}
                                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-gray-100 text-gray-600 text-xs font-semibold"><i class="bi bi-check-circle"></i> Terminée</span>
                                {% elseif req.session %}
                                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-blue-100 text-blue-700 text-xs font-semibold"><i class="bi bi-calendar-check"></i> Planifiée</span>
                                {% else %}
                                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-emerald-100 text-emerald-700 text-xs font-semibold"><i class="bi bi-check-lg"></i> Acceptée</span>
                                {% endif %}
                                {% if req.priority == 'urgent' %}
                                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-red-100 text-red-700 text-xs font-semibold"><i class="bi bi-exclamation-triangle-fill"></i> Urgent</span>
                                {% elseif req.priority == 'medium' %}
                                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-gray-100 text-gray-600 text-xs font-semibold">Faible</span>
                                {% else %}
                                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-blue-100 text-blue-700 text-xs font-semibold">Normal</span>
                                {% endif %}
                                {% if req.status == 'pending' and waitSec >= 172800 %}
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-red-50 text-red-600 border border-red-200 text-xs font-semibold"><i class="bi bi-alarm-fill"></i> &gt; 48h</span>
                                {% endif %}
                            </div>
                            <div class="flex flex-wrap gap-4 text-sm text-gray-500 mb-3">
                                <span><i class="bi bi-envelope me-1"></i>{{ req.user.email }}</span>
                                <span><i class="bi bi-calendar3 me-1"></i>{{ req.createdAt|date('d/m/Y à H:i') }}</span>
                                {% if req.status == 'pending' %}
                                    <span class="inline-flex items-center gap-1 text-amber-700">
                                        <i class="bi bi-hourglass-split"></i>
                                        {% if waitSec >= 86400 %}{{ (waitSec / 86400)|round(0, 'floor') }}j
                                        {% elseif waitSec >= 3600 %}{{ (waitSec / 3600)|round(0, 'floor') }}h
                                        {% else %}{{ (waitSec / 60)|round(0, 'floor') }}min{% endif %}
                                    </span>
                                {% endif %}
                            </div>
                            <div class="req-message-box relative bg-gray-50 border border-gray-200 rounded-xl py-3 px-4 pl-8 text-sm text-gray-600">{{ req.message }}</div>
                        </div>
                        <div class="flex sm:flex-col gap-2 flex-shrink-0">
                            {% if req.status == 'pending' %}
                                <form action="{{ path('app_coaching_request_accept', {id: req.id}) }}" method="post" class="accept-form">
                                    <input type="hidden" name="_token" value="{{ csrf_token('accept-request' ~ req.id) }}">
                                    <button type="submit" class="inline-flex items-center justify-center px-3 py-2.5 rounded-xl bg-emerald-100 text-emerald-700 hover:bg-emerald-200 font-semibold text-sm transition"><i class="bi bi-check-lg"></i></button>
                                </form>
                                <form action="{{ path('app_coaching_request_decline', {id: req.id}) }}" method="post" class="decline-form">
                                    <input type="hidden" name="_token" value="{{ csrf_token('decline-request' ~ req.id) }}">
                                    <button type="submit" class="inline-flex items-center justify-center px-3 py-2.5 rounded-xl bg-red-100 text-red-700 hover:bg-red-200 font-semibold text-sm transition"><i class="bi bi-x-lg"></i></button>
                                </form>
                            {% else %}
                                {% if req.status == 'accepted' and req.session %}
                                    <a href="{{ path('app_session_schedule', {id: req.session.id}) }}" class="inline-flex items-center justify-center gap-1.5 px-4 py-2.5 rounded-xl bg-orange-500 hover:bg-orange-600 text-white font-semibold text-sm shadow-md transition">
                                        <i class="bi bi-calendar-event"></i> Planifier
                                    </a>
                                {% endif %}
                                <form action="{{ path('app_coaching_request_pending', {id: req.id}) }}" method="post" class="pending-form">
                                    <input type="hidden" name="_token" value="{{ csrf_token('pending-request' ~ req.id) }}">
                                    <button type="submit" class="inline-flex items-center justify-center px-3 py-2.5 rounded-xl bg-amber-100 text-amber-700 hover:bg-amber-200 font-semibold text-sm transition" title="Remettre en attente"><i class="bi bi-arrow-counterclockwise"></i></button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% else %}
            <div class="bg-white border-2 border-dashed border-gray-200 rounded-2xl py-16 px-8 text-center">
                <div class="w-20 h-20 rounded-full bg-gradient-to-br from-orange-100 to-orange-200 flex items-center justify-center text-orange-500 text-4xl mx-auto mb-5">
                    <i class="bi bi-inbox"></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">Aucune demande pour le moment</h3>
                <p class="text-gray-500">Les demandes de coaching apparaîtront ici lorsque des utilisateurs vous contacteront.</p>
            </div>
        {% endif %}

    </div>
{% endblock %}

{% block javascripts %}
    <script>
        document.querySelectorAll('.accept-form, .decline-form, .pending-form').forEach(form => {
            form.addEventListener('submit', async function(e) {
                e.preventDefault();
                const btn = this.querySelector('button[type="submit"]');
                const html = btn ? btn.innerHTML : '';
                if (btn) { btn.disabled = true; btn.innerHTML = '<span class="inline-block w-4 h-4 border-2 border-current border-t-transparent rounded-full animate-spin"></span>'; }
                try {
                    const res = await fetch(this.action, { method: 'POST', body: new FormData(this), headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                    const data = await res.json();
                    if (data.success && data.redirect) window.location.href = data.redirect;
                    else if (data.success) location.reload();
                } finally {
                    if (btn) { btn.disabled = false; btn.innerHTML = html; }
                }
            });
        });
    </script>
{% endblock %}
