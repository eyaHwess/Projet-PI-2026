{# Goal History Timeline – used inside goal show page history section #}
<div class="goal-history-section">
    <div class="history-timeline">
        {% for entry in goalHistory %}
            {% set icon = 'bi-circle' %}
            {% set color = '#6b7280' %}
            {% set bg = '#f3f4f6' %}

            {% if entry.action == 'goal_created' %}
                {% set icon = 'bi-plus-circle-fill' %}
                {% set color = '#059669' %}
                {% set bg = '#d1fae5' %}
            {% elseif entry.action == 'status_changed' %}
                {% set icon = 'bi-arrow-left-right' %}
                {% set color = '#2563eb' %}
                {% set bg = '#dbeafe' %}
            {% elseif entry.action == 'goal_updated' %}
                {% set icon = 'bi-pencil-fill' %}
                {% set color = '#d97706' %}
                {% set bg = '#fef3c7' %}
            {% elseif entry.action == 'goal_deleted' %}
                {% set icon = 'bi-trash-fill' %}
                {% set color = '#dc2626' %}
                {% set bg = '#fee2e2' %}
            {% elseif entry.action == 'milestone_completed' %}
                {% set icon = 'bi-trophy-fill' %}
                {% set color = '#7c3aed' %}
                {% set bg = '#ede9fe' %}
            {% elseif entry.action == 'priority_changed' %}
                {% set icon = 'bi-flag-fill' %}
                {% set color = '#db2777' %}
                {% set bg = '#fce7f3' %}
            {% elseif entry.action == 'progress_updated' %}
                {% set icon = 'bi-bar-chart-fill' %}
                {% set color = '#0891b2' %}
                {% set bg = '#cffafe' %}
            {% elseif entry.action == 'deadline_set' %}
                {% set icon = 'bi-alarm-fill' %}
                {% set color = '#b45309' %}
                {% set bg = '#fef3c7' %}
            {% elseif entry.action == 'favorite_toggled' %}
                {% set icon = 'bi-star-fill' %}
                {% set color = '#ca8a04' %}
                {% set bg = '#fef9c3' %}
            {% endif %}

            <article class="history-item">
                <div class="history-line {% if loop.last %}history-line-last{% endif %}"></div>
                <div class="history-dot" style="background:{{ bg }};border-color:{{ color }}">
                    <i class="bi {{ icon }}" style="color:{{ color }}"></i>
                </div>
                <div class="history-card">
                    <div class="history-card-inner">
                        <div class="history-content">
                            <span class="history-action-badge" style="background:{{ bg }};color:{{ color }}">
                                {{ entry.actionLabel }}
                            </span>
                            {% if entry.description %}
                                <p class="history-desc mb-0 mt-2">{{ entry.description }}</p>
                            {% endif %}
                            {% if entry.oldStatus and entry.newStatus %}
                                <div class="d-flex align-items-center gap-2 mt-2 flex-wrap">
                                    <span class="status-pill status-pill-old">{{ entry.oldStatus|upper }}</span>
                                    <i class="bi bi-arrow-right history-arrow"></i>
                                    <span class="status-pill status-pill-new">{{ entry.newStatus|upper }}</span>
                                </div>
                            {% endif %}
                            {% if entry.metadata and entry.metadata|length > 0 %}
                                <div class="history-meta mt-2">
                                    {% for key, val in entry.metadata %}
                                        {% if val is iterable and (val.old is defined or val.new is defined) %}
                                            <span class="meta-chip">
                                                <strong>{{ key|replace({'_': ' '})|capitalize }}</strong>:
                                                {{ val.old ?? '—' }} → {{ val.new ?? '—' }}
                                            </span>
                                        {% else %}
                                            <span class="meta-chip">
                                                <strong>{{ key|replace({'_': ' '})|capitalize }}</strong>: {{ val }}
                                            </span>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                        <div class="history-meta-right">
                            <time class="history-time" datetime="{{ entry.createdAt|date('c') }}">
                                <i class="bi bi-calendar3 me-1"></i>{{ entry.createdAt|date('d/m/Y') }}
                                <span class="history-time-hour">{{ entry.createdAt|date('H:i') }}</span>
                            </time>
                            {% if entry.user %}
                                <div class="history-user">
                                    <i class="bi bi-person"></i>
                                    <span>{{ entry.user.firstName ?? entry.user.email|slice(0, 20) }}</span>
                                </div>
                            {% else %}
                                <div class="history-user history-user-system">
                                    <i class="bi bi-gear"></i> Système
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </article>
        {% endfor %}
    </div>
</div>
