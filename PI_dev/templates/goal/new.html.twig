{% extends 'base.html.twig' %}

{% block title %}Nouvel Objectif{% endblock %}

{% block stylesheets %}
<style>
:root {
    --primary: #5b4cdb;
    --primary-dark: #4a3cb8;
    --primary-light: #ede9fb;
    --border: #e9ecef;
    --bg: #f5f6fa;
    --text: #212529;
    --muted: #6c757d;
}

body { background: var(--bg); font-family: 'Inter', -apple-system, sans-serif; }

/* Page header */
.page-header {
    background: white;
    border-bottom: 1px solid var(--border);
    padding: 1.1rem 0;
    margin-bottom: 1.5rem;
}
.page-header h1 { font-size: 1.4rem; font-weight: 700; color: var(--text); margin: 0; }
.breadcrumb { font-size: 0.85rem; margin: 0.25rem 0 0; }
.breadcrumb-item a { color: var(--primary); text-decoration: none; }

/* Two-column layout */
.goal-layout {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
}
.goal-layout-left  { flex: 0 0 calc(60% - 0.75rem); min-width: 0; }
.goal-layout-right { flex: 0 0 calc(40% - 0.75rem); min-width: 0; }
@media (max-width: 900px) {
    .goal-layout { flex-direction: column; }
    .goal-layout-left, .goal-layout-right { flex: 0 0 100%; width: 100%; }
}

/* Form card */
.form-card {
    background: white;
    border-radius: 16px;
    border: 1px solid var(--border);
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    overflow: hidden;
}

/* Step tabs */
.step-tabs {
    display: flex;
    border-bottom: 1px solid var(--border);
}
.step-tab {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 1.25rem;
    border-bottom: 3px solid transparent;
    color: #adb5bd;
    font-size: 0.825rem;
    font-weight: 500;
    transition: all 0.2s;
}
.step-tab.active   { color: var(--primary); border-bottom-color: var(--primary); }
.step-tab.done     { color: #28a745; border-bottom-color: #28a745; }
.step-num {
    width: 26px; height: 26px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.75rem; font-weight: 700;
    background: #e9ecef; color: #adb5bd; flex-shrink: 0;
}
.step-tab.active .step-num { background: var(--primary-light); color: var(--primary); }
.step-tab.done   .step-num { background: #d4edda; color: #28a745; }

/* Steps */
.form-step { display: none; padding: 1.75rem; }
.form-step.active { display: block; animation: fadeIn 0.25s ease; }
@keyframes fadeIn { from { opacity:0; transform:translateX(8px); } to { opacity:1; transform:translateX(0); } }

/* Fields */
.form-label { font-weight: 600; font-size: 0.85rem; color: #495057; margin-bottom: 0.4rem; }
.form-control, .form-select {
    border: 1.5px solid var(--border); border-radius: 10px;
    padding: 0.7rem 1rem; font-size: 0.875rem; color: var(--text);
    width: 100%; background: white; transition: border-color 0.2s, box-shadow 0.2s;
}
.form-control:focus, .form-select:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(91,76,219,0.1);
    outline: none;
}
.form-control::placeholder { color: #ced4da; }
.field-hint { font-size: 0.78rem; color: var(--muted); margin-top: 0.3rem; }

/* Priority cards */
.priority-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 0.75rem; margin-top: 0.4rem; }
.pri-card {
    border: 2px solid var(--border); border-radius: 12px; padding: 0.9rem 0.5rem;
    text-align: center; cursor: pointer; transition: all 0.2s;
}
.pri-card:hover { border-color: #adb5bd; }
.pri-card.sel-low    { border-color: #28a745; background: #f0fff4; }
.pri-card.sel-medium { border-color: #fd7e14; background: #fff8f0; }
.pri-card.sel-high   { border-color: #dc3545; background: #fff5f5; }
.pri-icon { font-size: 1.6rem; margin-bottom: 0.35rem; }
.pri-lbl  { font-weight: 600; font-size: 0.8rem; color: #495057; }

/* Summary */
.summary-box { background: var(--bg); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
.summary-row { display: flex; padding: 0.65rem 1rem; border-bottom: 1px solid var(--border); }
.summary-row:last-child { border-bottom: none; }
.s-label { font-size: 0.75rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.4px; min-width: 130px; }
.s-val   { font-size: 0.875rem; color: var(--text); }

/* Footer */
.form-footer {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.25rem 1.75rem;
    background: var(--bg); border-top: 1px solid var(--border);
}
.btn-cancel, .btn-prev {
    display: flex; align-items: center; gap: 0.4rem;
    padding: 0.55rem 1.25rem; border: 1.5px solid var(--border);
    border-radius: 50px; background: white; color: var(--muted);
    font-weight: 600; font-size: 0.825rem; cursor: pointer; text-decoration: none;
    transition: all 0.2s;
}
.btn-cancel:hover, .btn-prev:hover { border-color: #adb5bd; color: #495057; }
.btn-next {
    display: flex; align-items: center; gap: 0.4rem;
    padding: 0.55rem 1.5rem; border: none; border-radius: 50px;
    background: linear-gradient(135deg, var(--primary), var(--primary-dark));
    color: white; font-weight: 600; font-size: 0.825rem; cursor: pointer;
    box-shadow: 0 4px 12px rgba(91,76,219,0.25); transition: all 0.2s;
}
.btn-next:hover { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(91,76,219,0.35); }
.btn-submit {
    display: flex; align-items: center; gap: 0.4rem;
    padding: 0.55rem 1.5rem; border: none; border-radius: 50px;
    background: linear-gradient(135deg, #28a745, #218838);
    color: white; font-weight: 600; font-size: 0.825rem; cursor: pointer;
    box-shadow: 0 4px 12px rgba(40,167,69,0.25); transition: all 0.2s;
}
.btn-submit:hover { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(40,167,69,0.35); }

/* AI sidebar */
.ai-sidebar { position: sticky; top: 70px; }
.ai-card {
    background: white; border-radius: 16px;
    border: 1px solid var(--border); box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    overflow: hidden;
}
.ai-card-head {
    background: linear-gradient(135deg, #1e1b4b, #312e81);
    padding: 1.1rem 1.25rem; color: white;
    display: flex; align-items: center; gap: 0.85rem;
}
.ai-robot-icon {
    width: 38px; height: 38px; background: rgba(255,255,255,0.15);
    border-radius: 10px; display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem; flex-shrink: 0;
}
.ai-card-head h3 { font-size: 0.95rem; font-weight: 700; margin: 0 0 0.1rem; }
.ai-card-head p  { font-size: 0.75rem; opacity: 0.75; margin: 0; }

.ai-list { padding: 0.75rem; max-height: 460px; overflow-y: auto; }
.ai-list::-webkit-scrollbar { width: 4px; }
.ai-list::-webkit-scrollbar-thumb { background: #ddd; border-radius: 2px; }

.ai-item {
    border: 1px solid var(--border); border-radius: 12px; padding: 0.9rem;
    margin-bottom: 0.6rem; transition: all 0.2s; background: var(--bg);
}
.ai-item:hover { border-color: var(--primary); box-shadow: 0 2px 8px rgba(91,76,219,0.1); }
.ai-item-top { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.4rem; }
.ai-badge {
    font-size: 0.7rem; font-weight: 600; padding: 0.15rem 0.55rem;
    border-radius: 50px; background: #e9ecef; color: #495057;
}
.ai-badge.high   { background: #fff0f0; color: #dc3545; }
.ai-badge.medium { background: #fff5e6; color: #fd7e14; }
.ai-badge.low    { background: #f0fff4; color: #28a745; }
.ai-days { font-size: 0.73rem; color: var(--muted); margin-left: auto; }
.ai-title { font-weight: 600; font-size: 0.85rem; color: var(--text); margin-bottom: 0.3rem; }
.ai-desc  { font-size: 0.78rem; color: var(--muted); line-height: 1.5; margin-bottom: 0.65rem; }
.ai-use {
    width: 100%; padding: 0.4rem; font-size: 0.78rem; font-weight: 600;
    border: 1.5px dashed var(--primary); border-radius: 8px;
    background: transparent; color: var(--primary); cursor: pointer; transition: all 0.2s;
}
.ai-use:hover { background: var(--primary-light); }

.ai-empty { text-align: center; padding: 2rem 1rem; color: var(--muted); }
.ai-empty i { font-size: 2.25rem; color: #ced4da; display: block; margin-bottom: 0.6rem; }
.ai-empty p { font-size: 0.83rem; margin: 0; }

/* Tips */
.tips-card {
    background: white; border-radius: 16px;
    border: 1px solid var(--border); padding: 1.1rem 1.25rem;
    margin-top: 1rem; box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}
.tips-head { font-weight: 700; font-size: 0.85rem; color: var(--text); margin-bottom: 0.65rem; }
.tips-head i { color: #ffc107; }
.tips-list { list-style: none; padding: 0; margin: 0; }
.tips-list li {
    font-size: 0.8rem; color: var(--muted); padding: 0.3rem 0 0.3rem 1.1rem;
    border-bottom: 1px solid #f0f0f0; position: relative;
}
.tips-list li:last-child { border-bottom: none; }
.tips-list li::before { content: '✓'; position: absolute; left: 0; color: #28a745; font-weight: 700; }
</style>
{% endblock %}

{% block body %}

<div class="page-header">
    <div style="max-width:1200px;margin:0 auto;padding:0 1.5rem">
        <h1><i class="bi bi-plus-circle me-2"></i>Nouvel Objectif</h1>
        <nav><ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_goal_index') }}">Objectifs</a></li>
            <li class="breadcrumb-item active">Créer</li>
        </ol></nav>
    </div>
</div>

<div style="max-width:1200px;margin:0 auto;padding:0 1.5rem 3rem">
<div class="goal-layout">

    {# ── Left: form card ── #}
    <div class="goal-layout-left">
    <div class="form-card">

        {# Step tabs #}
        <div class="step-tabs">
            <div class="step-tab active" id="tab-1">
                <div class="step-num">1</div>
                <div><div style="font-size:.7rem;opacity:.7">Étape 1</div><div>Informations</div></div>
            </div>
            <div class="step-tab" id="tab-2">
                <div class="step-num">2</div>
                <div><div style="font-size:.7rem;opacity:.7">Étape 2</div><div>Planning</div></div>
            </div>
            <div class="step-tab" id="tab-3">
                <div class="step-num">3</div>
                <div><div style="font-size:.7rem;opacity:.7">Étape 3</div><div>Confirmation</div></div>
            </div>
        </div>

        {{ form_start(form, {'attr': {'id': 'goalForm', 'novalidate': 'novalidate'}}) }}

        {# Step 1 #}
        <div class="form-step active" id="step-1">
            <p style="font-weight:700;color:var(--text);margin-bottom:1.25rem">
                <i class="bi bi-pencil-square" style="color:var(--primary)"></i> Décrivez votre objectif
            </p>

            <div class="mb-3">
                {{ form_label(form.title, 'Titre de l\'objectif', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.title, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Perdre 5 kg en 2 mois', 'id': 'f-title', 'autocomplete': 'off'}}) }}
                {{ form_errors(form.title) }}
                <div class="field-hint">Soyez précis et motivant dans votre titre.</div>
            </div>

            <div class="mb-3">
                {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4, 'placeholder': 'Décrivez votre objectif, pourquoi il est important pour vous...', 'id': 'f-desc'}}) }}
                {{ form_errors(form.description) }}
                <div class="field-hint">Plus vous êtes précis, plus il sera facile de suivre vos progrès.</div>
            </div>

            {# Priority — visual cards backed by hidden select #}
            <div class="mb-1">
                <label class="form-label">Priorité</label>
                <div class="priority-grid">
                    <div class="pri-card sel-low" id="pc-low"    onclick="setPriority('low')">
                        <div class="pri-icon">🟢</div><div class="pri-lbl">Faible</div>
                    </div>
                    <div class="pri-card" id="pc-medium" onclick="setPriority('medium')">
                        <div class="pri-icon">🟠</div><div class="pri-lbl">Moyenne</div>
                    </div>
                    <div class="pri-card" id="pc-high"   onclick="setPriority('high')">
                        <div class="pri-icon">🔴</div><div class="pri-lbl">Haute</div>
                    </div>
                </div>
                <div style="display:none">{{ form_widget(form.priority, {'attr': {'id': 'f-priority'}}) }}</div>
                {{ form_errors(form.priority) }}
            </div>
        </div>

        {# Step 2 #}
        <div class="form-step" id="step-2">
            <p style="font-weight:700;color:var(--text);margin-bottom:1.25rem">
                <i class="bi bi-calendar3" style="color:var(--primary)"></i> Planifiez votre objectif
            </p>

            <div style="display:flex;gap:1rem;margin-bottom:1rem">
                <div style="flex:1;min-width:0">
                    {{ form_label(form.startDate, 'Date de début', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.startDate, {'attr': {'class': 'form-control', 'id': 'f-start'}}) }}
                    {{ form_errors(form.startDate) }}
                </div>
                <div style="flex:1;min-width:0">
                    {{ form_label(form.endDate, 'Date de fin', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.endDate, {'attr': {'class': 'form-control', 'id': 'f-end'}}) }}
                    {{ form_errors(form.endDate) }}
                </div>
            </div>

            <div class="mb-3">
                {{ form_label(form.status, 'Statut', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.status, {'attr': {'class': 'form-select', 'id': 'f-status'}}) }}
                {{ form_errors(form.status) }}
                <div class="field-hint">Le statut peut être modifié à tout moment.</div>
            </div>

            {% if form.deadline is defined %}
            <div class="mb-3">
                {{ form_label(form.deadline, 'Deadline (optionnel)', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.deadline, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.deadline) }}
            </div>
            {% endif %}
        </div>

        {# Step 3 #}
        <div class="form-step" id="step-3">
            <p style="font-weight:700;color:var(--text);margin-bottom:1.25rem">
                <i class="bi bi-check2-circle" style="color:var(--primary)"></i> Vérifiez avant de créer
            </p>

            <div class="summary-box">
                <div class="summary-row"><span class="s-label">Titre</span><span class="s-val" id="s-title">—</span></div>
                <div class="summary-row"><span class="s-label">Description</span><span class="s-val" id="s-desc">—</span></div>
                <div class="summary-row"><span class="s-label">Priorité</span><span class="s-val" id="s-priority">—</span></div>
                <div class="summary-row"><span class="s-label">Date de début</span><span class="s-val" id="s-start">—</span></div>
                <div class="summary-row"><span class="s-label">Date de fin</span><span class="s-val" id="s-end">—</span></div>
                <div class="summary-row"><span class="s-label">Statut</span><span class="s-val" id="s-status">—</span></div>
            </div>

            <div class="mt-3 p-3" style="background:var(--primary-light);border-radius:10px;font-size:0.82rem;color:var(--primary)">
                <i class="bi bi-info-circle me-1"></i> Vous pourrez modifier cet objectif à tout moment depuis votre tableau de bord.
            </div>
        </div>

        {{ form_end(form) }}

        {# Footer navigation #}
        <div class="form-footer">
            <div id="left-btn">
                <a href="{{ path('app_goal_index') }}" class="btn-cancel" id="btn-cancel">
                    <i class="bi bi-arrow-left"></i> Annuler
                </a>
                <button type="button" class="btn-prev" id="btn-prev" style="display:none" onclick="goPrev()">
                    <i class="bi bi-arrow-left"></i> Retour
                </button>
            </div>
            <div>
                <button type="button" class="btn-next" id="btn-next" onclick="goNext()">
                    Suivant <i class="bi bi-arrow-right"></i>
                </button>
                <button type="submit" form="goalForm" class="btn-submit" id="btn-submit" style="display:none">
                    <i class="bi bi-check2"></i> Créer l'objectif
                </button>
            </div>
        </div>

    </div>{# end form-card #}
    </div>{# end goal-layout-left #}

    {# ── Right: AI sidebar ── #}
    <div class="goal-layout-right">
    <div class="ai-sidebar">
        <div class="ai-card">
            <div class="ai-card-head">
                <div class="ai-robot-icon"><i class="bi bi-robot"></i></div>
                <div>
                    <h3>Suggestions IA</h3>
                    <p>Objectifs recommandés pour vous</p>
                </div>
            </div>
            <div class="ai-list">
                {% if aiSuggestions is defined and aiSuggestions|length > 0 %}
                    {% for item in aiSuggestions %}
                    <div class="ai-item">
                        <div class="ai-item-top">
                            <span class="ai-badge {{ (item.priority|default('medium'))|lower }}">
                                {% if (item.priority|default(''))|lower == 'high' %}🔴 High
                                {% elseif (item.priority|default(''))|lower == 'medium' %}🟠 Medium
                                {% else %}🟢 Low{% endif %}
                            </span>
                            {% if item.duration_days is defined %}
                            <span class="ai-days"><i class="bi bi-calendar3"></i> {{ item.duration_days }}j</span>
                            {% endif %}
                        </div>
                        <div class="ai-title">{{ item.title|default('') }}</div>
                        <div class="ai-desc">{{ item.description|default('') }}</div>
                        <button type="button" class="ai-use"
                            data-title="{{ item.title|default('')|e('html_attr') }}"
                            data-desc="{{ item.description|default('')|e('html_attr') }}"
                            data-priority="{{ (item.priority|default('low'))|lower }}"
                            onclick="useSuggestion(this)">
                            <i class="bi bi-plus-circle"></i> Utiliser cette suggestion
                        </button>
                    </div>
                    {% endfor %}
                {% else %}
                    <div class="ai-empty">
                        <i class="bi bi-stars"></i>
                        <p>Créez votre premier objectif pour recevoir des suggestions personnalisées.</p>
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="tips-card">
            <div class="tips-head"><i class="bi bi-lightbulb-fill"></i> Conseils SMART</div>
            <ul class="tips-list">
                <li><strong>Spécifique</strong> — Définissez exactement ce que vous voulez atteindre.</li>
                <li><strong>Mesurable</strong> — Ajoutez des critères de réussite clairs.</li>
                <li><strong>Réaliste</strong> — Choisissez une deadline atteignable.</li>
            </ul>
        </div>
    </div>{# end ai-sidebar #}
    </div>{# end goal-layout-right #}

</div>{# end goal-layout #}
</div>{# end container #}

<script>
(function () {
    var step = 1;
    var priority = 'low';
    var priLabels = { low: '🟢 Faible', medium: '🟠 Moyenne', high: '🔴 Haute' };

    function showStep(n) {
        for (var i = 1; i <= 3; i++) {
            var s = document.getElementById('step-' + i);
            var t = document.getElementById('tab-' + i);
            s.classList.remove('active');
            t.classList.remove('active', 'done');
            if (i < n)  t.classList.add('done');
            if (i === n) { s.classList.add('active'); t.classList.add('active'); }
        }
        var cancel = document.getElementById('btn-cancel');
        var prev   = document.getElementById('btn-prev');
        var next   = document.getElementById('btn-next');
        var submit = document.getElementById('btn-submit');
        cancel.style.display = (n === 1) ? ''     : 'none';
        prev.style.display   = (n > 1)   ? ''     : 'none';
        next.style.display   = (n < 3)   ? ''     : 'none';
        submit.style.display = (n === 3) ? ''     : 'none';
        if (n === 3) fillSummary();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    window.goNext = function () {
        if (step < 3) { step++; showStep(step); }
    };
    window.goPrev = function () {
        if (step > 1) { step--; showStep(step); }
    };

    window.setPriority = function (val) {
        priority = val;
        ['low','medium','high'].forEach(function(v) {
            document.getElementById('pc-' + v).classList.remove('sel-low','sel-medium','sel-high');
        });
        document.getElementById('pc-' + val).classList.add('sel-' + val);
        // sync hidden select — find by name regardless of generated ID
        var sel = document.querySelector('#goalForm [name$="[priority]"]');
        if (sel) sel.value = val;
    };

    function fillSummary() {
        var form = document.getElementById('goalForm');
        var t  = form.querySelector('[name$="[title]"]');
        var d  = form.querySelector('[name$="[description]"]');
        var s  = form.querySelector('[name$="[startDate]"]');
        var e  = form.querySelector('[name$="[endDate]"]');
        var st = form.querySelector('[name$="[status]"]');
        document.getElementById('s-title').textContent    = (t  && t.value)  ? t.value  : '—';
        document.getElementById('s-desc').textContent     = (d  && d.value)  ? d.value  : '—';
        document.getElementById('s-priority').textContent = priLabels[priority] || '—';
        document.getElementById('s-start').textContent    = (s  && s.value)  ? s.value  : '—';
        document.getElementById('s-end').textContent      = (e  && e.value)  ? e.value  : '—';
        document.getElementById('s-status').textContent   = (st && st.selectedIndex >= 0) ? st.options[st.selectedIndex].text : '—';
    }

    window.useSuggestion = function (btn) {
        var title = btn.getAttribute('data-title') || '';
        var desc  = btn.getAttribute('data-desc')  || '';
        var prio  = btn.getAttribute('data-priority') || 'low';

        // Find fields by name attribute (works regardless of generated IDs)
        var titleEl = document.querySelector('#goalForm [name$="[title]"], #goalForm [name="goal[title]"]');
        var descEl  = document.querySelector('#goalForm [name$="[description]"], #goalForm [name="goal[description]"]');

        if (titleEl) titleEl.value = title;
        if (descEl)  descEl.value  = desc;
        setPriority(prio);
        step = 1;
        showStep(1);

        // flash fields
        [titleEl, descEl].forEach(function(el) {
            if (!el) return;
            el.style.transition = 'background 0.4s';
            el.style.background = '#ede9fb';
            setTimeout(function() { el.style.background = ''; }, 1000);
        });
    };

    // init
    setPriority('low');
    showStep(1);
})();
</script>
{% endblock %}
