{% extends 'base.html.twig' %}

{% block title %}Login{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center bg-rose-50">

    <div class="w-full max-w-md bg-white rounded-3xl shadow-xl p-8">

        <!-- Logo / App name -->
        <div class="text-center mb-6">
            <div class="mx-auto mb-3 h-12 w-12 rounded-full bg-blue-200 flex items-center justify-center">
                💙
            </div>
            <h2 class="text-2xl font-bold text-gray-700">
                Welcome back
            </h2>
            <p class="text-sm text-gray-500 mt-1">
                Organize your routine, gently
            </p>
        </div>

        {% for message in app.flashes('success') %}
            <div class="mb-4 rounded-xl bg-green-100 p-3 text-sm text-green-800">
                {{ message }}
            </div>
        {% endfor %}

        {% for message in app.flashes('login_error') %}
            <div class="mb-4 rounded-xl bg-rose-100 p-3 text-sm text-rose-700">
                {{ message }}
            </div>
        {% endfor %}
        {% if error %}
            <div class="mb-4 rounded-xl bg-rose-100 p-3 text-sm text-rose-700">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post" class="space-y-5">

            <div>
                <label class="block text-sm font-medium text-gray-600">
                    Email
                </label>
                <input
                    type="email"
                    name="_username"
                    value="{{ last_username }}"
                    required
                    autofocus
                    class="mt-1 w-full rounded-xl border border-gray-300 px-4 py-2
                           focus:border-blue-400 focus:ring-2 focus:ring-blue-200 outline-none"
                >
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-600 mb-1">
                    Password
                </label>
                <input
                    type="password"
                    name="_password"
                    required
                    class="mt-1 w-full rounded-xl border border-gray-300 px-4 py-2
                           focus:border-blue-400 focus:ring-2 focus:ring-blue-200 outline-none"
                >
                <div class="text-right mt-1">
                    <a href="{{ path('app_forgot_password_request') }}"
                       class="text-xs text-blue-500 hover:underline">
                        Forgot password?
                    </a>
                </div>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button
                type="submit"
                class="w-full rounded-xl bg-blue-400 py-2.5 text-white font-semibold
                       hover:bg-blue-500 transition"
            >
                Sign in 🌸
            </button>
        </form>

        <!-- Divider -->
        <div class="flex items-center my-5">
            <div class="flex-1 border-t border-gray-200"></div>
            <span class="mx-3 text-xs text-gray-400">or</span>
            <div class="flex-1 border-t border-gray-200"></div>
        </div>

        <!-- Google Login -->
        <a href="{{ path('connect_google') }}"
           class="flex items-center justify-center gap-3 w-full rounded-xl border border-gray-300
                  py-2.5 text-sm font-medium text-gray-600 hover:bg-gray-50 transition">
            <svg class="w-5 h-5" viewBox="0 0 48 48">
                <path fill="#FFC107" d="M43.6 20.1H42V20H24v8h11.3C33.7 32.7 29.2 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.8 1.1 7.9 3l5.7-5.7C34.5 6.5 29.5 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.7-.4-3.9z"/>
                <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 16 19.1 12 24 12c3.1 0 5.8 1.1 7.9 3l5.7-5.7C34.5 6.5 29.5 4 24 4 16.3 4 9.7 8.3 6.3 14.7z"/>
                <path fill="#4CAF50" d="M24 44c5.2 0 9.9-2 13.4-5.2l-6.2-5.2C29.3 35.5 26.8 36 24 36c-5.2 0-9.6-3.3-11.3-8H6.1C9.5 35.7 16.3 44 24 44z"/>
                <path fill="#1976D2" d="M43.6 20.1H42V20H24v8h11.3c-.8 2.3-2.3 4.2-4.2 5.6l6.2 5.2C40.6 35.5 44 30.2 44 24c0-1.3-.1-2.7-.4-3.9z"/>
            </svg>
            Continue with Google
        </a>

        <!-- Register link -->
        <p class="mt-5 text-center text-sm text-gray-500">
            Don't have an account?
            <a href="{{ path('app_register') }}" class="text-blue-500 font-medium hover:underline">
                Sign up
            </a>
        </p>

        <p class="mt-4 text-center text-xs text-gray-400">
            Your well-being, one habit at a time ✨
        </p>
    </div>
</div>
{% endblock %}
